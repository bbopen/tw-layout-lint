{
  "name": "tw-layout-lint",
  "version": "0.1.0",
  "description": "Layout-only class validator for Tailwind CSS agent output, with stable diagnostic codes and a finite runtime safelist. For Tailwind CSS v4.",
  "license": "MIT",
  "keywords": [
    "tailwind",
    "tailwindcss",
    "tailwind-v4",
    "layout",
    "validator",
    "lint",
    "agent",
    "llm",
    "generative-ui",
    "container-queries"
  ],
  "type": "module",
  "files": [
    "dist",
    "docs/skills",
    "docs/diagnostics.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs"
    },
    "./source.css": "./dist/source.css",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup && npm run build:source-css && npm run build:diagnostics",
    "build:source-css": "tsx scripts/gen-source-css.ts",
    "build:diagnostics": "tsx scripts/gen-diagnostics-md.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.0",
    "@vitest/coverage-v8": "^4.0.0",
    "happy-dom": "^20.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bbopen/tw-layout-lint.git"
  },
  "homepage": "https://github.com/bbopen/tw-layout-lint#readme",
  "bugs": {
    "url": "https://github.com/bbopen/tw-layout-lint/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
